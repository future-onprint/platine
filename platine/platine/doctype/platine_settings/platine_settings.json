  {
   "default": "0",
   "description": "When enabled, the browser uploads files directly to S3 via a presigned PUT URL \u2014 the Frappe server handles only signing, never file content.",
   "fieldname": "presigned_upload_enabled",
   "fieldtype": "Check",
   "label": "Enable Presigned Upload"
  },
  {
   "default": "60",
